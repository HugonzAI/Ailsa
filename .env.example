# OpenAI key for Whisper transcription
# OPENAI_API_KEY=sk-...

# Primary note-generation model provider
# ANTHROPIC_API_KEY=sk-ant-...

# Default Claude model for note generation
ANTHROPIC_MODEL=claude-sonnet-4-6

# Set to 1 to use mock SOAP note generation while scaffolding
MOCK_NOTE_GENERATION=1

# Set to 1 to use mock transcription instead of Whisper API
MOCK_TRANSCRIPTION=1
