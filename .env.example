# OpenAI key for Whisper transcription
# OPENAI_API_KEY=sk-...

# Primary note-generation model provider
# MINIMAX_API_KEY=...

# Default MiniMax model for note generation
MINIMAX_MODEL=MiniMax-M2.7

# Set to 1 to use mock SOAP note generation while scaffolding
MOCK_NOTE_GENERATION=1

# Set to 1 to use mock transcription instead of provider transcription API
MOCK_TRANSCRIPTION=1

# Optional transcription model override for real mode
# OPENAI_TRANSCRIBE_MODEL=whisper-1
